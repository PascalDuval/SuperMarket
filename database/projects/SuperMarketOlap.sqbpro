<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="../db/SuperMarketOlap.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="browser pragmas query" current="2"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2435"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="LogsPourInsert" custom_title="0" dock_id="1" table="4,14:mainLogsPourInsert"/><dock_state state="000000ff00000000fd0000000100000002000005a80000038efc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000005a80000013700ffffff0000025b0000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Dim_Calendrier" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="93"/><column index="2" value="46"/><column index="3" value="39"/><column index="4" value="85"/><column index="5" value="78"/><column index="6" value="85"/><column index="7" value="101"/><column index="8" value="78"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Dim_Clients" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="140"/><column index="2" value="132"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Dim_Produits" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="109"/><column index="2" value="202"/><column index="3" value="156"/><column index="4" value="241"/><column index="5" value="46"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Faits_Ventes" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="280"/><column index="2" value="140"/><column index="3" value="257"/><column index="4" value="109"/><column index="5" value="85"/><column index="6" value="78"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="LogsPourInsert" show_row_id="0" encoding="" plot_x_axis="field3" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="0" mode="1"/></sort><column_widths><column index="1" value="265"/><column index="2" value="109"/><column index="3" value="78"/><column index="4" value="101"/><column index="5" value="280"/><column index="6" value="132"/><column index="7" value="257"/><column index="8" value="40"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT ROUND(SUM(p.prix), 2) AS chiffre_affaires_total
FROM Faits_Ventes f
JOIN Dim_Produits p ON f.EAN = p.EAN
WHERE f.Date_Achat = '45518';  -- 14 août 2024 (date Excel)</sql><sql name="SQL 2*">SELECT f.CUSTOMER_ID,
       ROUND(SUM(p.prix), 2) AS chiffre_affaires
FROM Faits_Ventes f
JOIN Dim_Produits p ON f.EAN = p.EAN
GROUP BY f.CUSTOMER_ID
ORDER BY chiffre_affaires DESC
LIMIT 10;</sql><sql name="SQL 3*">SELECT f.id_employe,
       ROUND(SUM(p.prix), 2) AS chiffre_affaires,
       ROUND(100.0 * SUM(p.prix) / (SELECT SUM(p2.prix)
                                    FROM Faits_Ventes f2
                                    JOIN Dim_Produits p2 ON f2.EAN = p2.EAN), 2) AS part_pourcentage
FROM Faits_Ventes f
JOIN Dim_Produits p ON f.EAN = p.EAN
GROUP BY f.id_employe
ORDER BY chiffre_affaires DESC;</sql><sql name="SQL 4*">CREATE TABLE Logs (
    id_user CHAR(32) NOT NULL,        -- identifiant de l’utilisateur (hash)
    date_ecriture INTEGER NOT NULL,            -- date Excel (ex: 45518)
    operation TEXT NOT NULL,             -- type d’action (INSERT, UPDATE, DELETE…)
    table_concerne TEXT NOT NULL,       -- table impactée (ex: Client, Ventes…)
    id_ligne TEXT NOT NULL,           -- identifiant de la ligne impactée (ex: CUSTOMER_ID)
    champs_impacte TEXT NOT NULL,             -- nom de la colonne impactée
    detail TEXT NOT NULL              -- valeur détaillée (ex: '14/08/2024')
);
</sql><sql name="SQL 5*">DROP TABLE IF EXISTS Logs;
DROP TABLE IF EXISTS LogsPourInsert;
</sql><sql name="SQL 6*">DELETE FROM LogsPourInsert
WHERE rowid = (SELECT MIN(rowid) FROM LogsPourInsert);

</sql><sql name="SQL 7*">SELECT 
    strftime('%d/%m/%Y', date('1899-12-30', '+' || date_ecriture || ' days')) AS excel_todate,
    operation,
    table_insert,
    COUNT(*) AS nb_operations
FROM LogsPourInsert
GROUP BY 
    excel_todate, 
    operation, 
    table_insert
ORDER BY 
    excel_todate, 
    operation, 
    table_insert;
</sql><sql name="SQL 8*">SELECT SUM(p.prix) AS ca_14
FROM Faits_Ventes f
JOIN Dim_Produits p ON f.EAN = p.EAN
WHERE f.ID_BDD IN (
  SELECT DISTINCT id_ligne
  FROM LogsPourInsert
  WHERE date_ecriture = 45518
    AND UPPER(operation) = 'INSERT'
    AND LOWER(table_insert) LIKE '%ventes%'
);
</sql><sql name="SQL 9*">SELECT SUM(p.prix) AS ca_15
FROM Faits_Ventes f
JOIN Dim_Produits p ON f.EAN = p.EAN
WHERE f.ID_BDD IN (
  SELECT DISTINCT id_ligne
  FROM LogsPourInsert
  WHERE date_ecriture = 45519
    AND UPPER(operation) = 'INSERT'
    AND LOWER(table_insert) LIKE '%ventes%'
);
</sql><sql name="SQL 10*">SELECT SUM(p.prix) AS ca_total
FROM Faits_Ventes f
JOIN Dim_Produits p ON f.EAN = p.EAN
WHERE f.ID_BDD IN (
  SELECT DISTINCT id_ligne
  FROM LogsPourInsert
  WHERE date_ecriture IN (45518, 45519)
    AND UPPER(operation) = 'INSERT'
    AND LOWER(table_insert) LIKE '%ventes%'
);
</sql><sql name="SQL 11*">SELECT 'CA logué le 14/08/2024' AS libelle,
       REPLACE(printf('%.2f', SUM(p.prix)), '.', ',') || ' €' AS montant
FROM Faits_Ventes f
JOIN Dim_Produits p ON p.EAN = f.EAN
WHERE f.ID_BDD IN (
  SELECT id_ligne
  FROM LogsPourInsert
  WHERE CAST(date_ecriture AS INTEGER) = 45518
    AND UPPER(operation) = 'INSERT'
    AND LOWER(table_insert) LIKE '%ventes%'
)
UNION ALL
SELECT 'CA logué le 15/08/2024',
       REPLACE(printf('%.2f', SUM(p.prix)), '.', ',') || ' €'
FROM Faits_Ventes f
JOIN Dim_Produits p ON p.EAN = f.EAN
WHERE f.ID_BDD IN (
  SELECT id_ligne
  FROM LogsPourInsert
  WHERE CAST(date_ecriture AS INTEGER) = 45519
    AND UPPER(operation) = 'INSERT'
    AND LOWER(table_insert) LIKE '%ventes%'
)
UNION ALL
SELECT 'CA cumulé (14 + 15 aout)',
       REPLACE(printf('%.2f', SUM(p.prix)), '.', ',') || ' €'
FROM Faits_Ventes f
JOIN Dim_Produits p ON p.EAN = f.EAN
WHERE f.ID_BDD IN (
  SELECT id_ligne
  FROM LogsPourInsert
  WHERE CAST(date_ecriture AS INTEGER) IN (45518, 45519)
    AND UPPER(operation) = 'INSERT'
    AND LOWER(table_insert) LIKE '%ventes%'
);
</sql><current_tab id="10"/></tab_sql></sqlb_project>



